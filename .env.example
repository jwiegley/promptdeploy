# promptdeploy - Environment variables required by MCP server definitions
#
# Copy this file to .env and fill in your values.
# These variables are referenced via ${VAR} syntax in mcp/*.yaml files.
# Your shell must export them before running promptdeploy deploy.

# Anthropic (used by: pal, task-master-ai)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (used by: pal)
GEMINI_API_KEY=AIza...

# OpenAI (used by: pal)
OPENAI_API_KEY=sk-proj-...

# Perplexity (used by: perplexity, task-master-ai)
PERPLEXITY_API_KEY=pplx-...

# LiteLLM proxy (used by: models)
LITELLM_API_KEY=sk-...

# Qdrant vector store (used by: mem0)
MEM0_QDRANT_API_KEY=...
